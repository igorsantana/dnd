# Copy this file to .env and set your own passwords.
# Never commit .env — it is gitignored.

VITE_PLAYER_PASSWORD=your-player-password
VITE_ADMIN_PASSWORD=your-admin-password

# Server-side passwords for /api/characters (set these on Vercel too)
PLAYER_PASSWORD=your-player-password
ADMIN_PASSWORD=your-admin-password

# Upstash Redis (Vercel Marketplace → auto-injected)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
